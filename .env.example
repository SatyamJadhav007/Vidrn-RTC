# =============================================================================
# Vidrn-RTC environment variables
# Copy to `.env` at the repo root for docker-compose, or to `backend/.env` for
# local `npm run dev`. Never commit real secrets.
# =============================================================================

# --- Core (required) ---
PORT=5001
NODE_ENV=development
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/vidrn?retryWrites=true&w=majority
JWT_SECRET_KEY=your_jwt_secret

# --- Redis ---
# Local Docker Compose uses the bundled Redis service:
REDIS_URL=redis://redis:6379

# Render production uses Upstash (TLS). Keep this unset when using REDIS_URL.
# UPSTASH_REDIS_URL=rediss://default:xxx@xxx.upstash.io:6379

# --- CORS (comma-separated origins) ---
# Docker Compose frontend is served at http://localhost:8080
CORS_ORIGINS=http://localhost:5173,http://localhost:8080

# --- Deployment mode ---
# Render monolith serves frontend/dist from the backend (default when unset).
# Docker/AWS split stack sets this to false on the backend container only.
# SERVE_FRONTEND=false

# --- Frontend build (Docker / AWS only — baked in at image build time) ---
# VITE_API_URL=/api
# VITE_SOCKET_URL=

# --- TURN server (Phase 2) ---
# TURN_SECRET=
# TURN_URL=turn:your-turn-host:3478
