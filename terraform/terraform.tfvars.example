# ==============================================================================
# Vidrn-RTC Terraform Variables Example
# Copy this file to "terraform.tfvars" and fill in your actual values.
# IMPORTANT: "terraform.tfvars" is ignored by git so your secrets stay safe.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. AWS Container Images (Required)
# ------------------------------------------------------------------------------
# Replace <aws_account_id> with your actual 12-digit AWS account ID.
# Replace ap-south-1 with your region if different.
backend_image  = "<aws_account_id>.dkr.ecr.ap-south-1.amazonaws.com/vidrn-backend:latest"
frontend_image = "<aws_account_id>.dkr.ecr.ap-south-1.amazonaws.com/vidrn-frontend:latest"


# ------------------------------------------------------------------------------
# 2. Application Secrets (Required)
# ------------------------------------------------------------------------------
# MongoDB connection string (Make sure to whitelist 0.0.0.0/0 in Atlas temporarily)
mongo_uri   = "mongodb+srv://<user>:<password>@<cluster>.mongodb.net/vidrn?retryWrites=true&w=majority"

# JWT Secret for signing auth tokens (can be any secure random string)
jwt_secret  = "your_super_secret_jwt_key_here"

# TURN Server shared secret (must match what coturn expects)
turn_secret = "your_turn_secret_key_here"


# ------------------------------------------------------------------------------
# 3. Optional Overrides (Uncomment to change from default)
# ------------------------------------------------------------------------------

# aws_region             = "ap-south-1"
# project_name           = "vidrn"

# Number of ECS tasks to run. 
# 2 backend tasks proves horizontal scaling (Redis Socket.IO adapter)
# backend_desired_count  = 2
# frontend_desired_count = 1

# If you want to SSH into your coturn EC2 instance, specify your AWS Key Pair name
# ec2_key_pair_name      = "vidrn-turn-key"

# Restrict SSH access to your specific IP address (e.g. "203.0.113.50/32")
# ssh_allowed_cidr       = "0.0.0.0/0"
